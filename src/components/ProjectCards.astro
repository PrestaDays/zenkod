---
const projects = [
    {
        image: "/assets/logo_althers.png",
        title: "iWorkout",
        description: "iWorkout est une application mobile qui fourni un plan de musculation en fonction des objectifs définis par l'utilisateur.",
        link: "https://apps.apple.com/fr/app/iworkout/id6745475949"
    },
    {
        image: "/assets/logo_raltech.png",
        title: "Raltech",
        description: "Raltech est une école de code en ligne avec laquelle nous avons collaboré pour la conception de leur site internet.",
        link: "https://raltech.school/"
    },
    {
        image: "/assets/logo_quiz.png",
        title: "QuizMaster",
        description: "QuizMaster est une application web interactive permettant de participer à des quiz en temps réel.",
        link: "https://quiz.lucesf.com/"
    }
];
---

<div class="w-full max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 md:gap-12">
        {projects.map((project) => (
            <div
                class="bg-[#FEF6F0] rounded-xl p-8 md:p-10 transform transition-all duration-300 hover:scale-105 hover:shadow-xl"
            >
                <div class="flex flex-col items-center space-y-6">
                    <div class="w-40 h-40 flex items-center justify-center p-4">
                        <img
                            src={project.image}
                            alt={project.title}
                            width="160"
                            height="160"
                            loading="lazy"
                            decoding="async"
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-2xl font-bold text-center">
                        {project.title}
                    </h3>
                    <p class="text-gray-700 text-center">
                        {project.description}
                    </p>
                    {project.link && (
                        <a
                            href={project.link}
                            target="_blank"
                            class="bg-accent text-white px-6 py-2 rounded-lg hover:bg-accent/90 transition-colors duration-200"
                        >
                            Voir le projet
                        </a>
                    )}
                </div>
            </div>
        ))}
    </div>
</div>
