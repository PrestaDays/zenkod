---
import '../styles/index.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCards from '../components/ProjectCards.astro';

const pageTitle = "zenkod | Agence Web - Création de Sites & Applications";
const description = "zenkod, agence web créative. Sites vitrines, e-commerce, applications mobiles et API sur mesure. Découvrez nos réalisations et transformez votre présence digitale.";
---

<BaseLayout pageTitle={pageTitle} description={description}>
  <main class="min-h-screen w-full pt-16">
    <div class="flex flex-col items-center pb-12">
      <div class="text-center space-y-8 mb-16 w-full mx-auto bg-primary p-8 rounded-lg">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
          Nous créons l'avenir
        </h1>

        <div class="space-y-4 max-w-3xl mx-auto">
          <div class="text-xl sm:text-2xl font-medium">
            <span class="text-accent font-bold">Zenkod</span>
            <span> est une agence numérique à service complet spécialisée dans la conception de sites web.</span>
          </div>

          <div class="flex justify-center">
            <a
                href="/about"
                class="inline-block px-8 py-3 text-lg font-medium rounded-lg bg-tertiary text-white transform transition-all duration-300 hover:scale-110"
            >
              En savoir plus
            </a>
          </div>
        </div>
      </div>

      <div class="w-3/4 sm:px-6 lg:px-8 space-y-12">
        <p class="text-lg sm:text-xl text-center max-w-4xl mx-auto mb-10">
          Notre agence mène de nombreux projets chaque année pour une variété de clients,
          incluant la création et la refonte de sites web. Pour vous donner un aperçu,
          voici une sélection de sites web et d'applications que nous avons réalisés.
        </p>

        <ProjectCards />
      </div>
    </div>
  </main>
</BaseLayout>